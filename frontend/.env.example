# URL pubblico di Strapi (usato anche dal browser per le immagini)
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337

# Token read-only opzionale. Se vuoto, l'API di Strapi deve avere il ruolo
# Public abilitato in lettura (find/findOne) per i content type usati.
STRAPI_API_TOKEN=

# Preview: stesso valore del PREVIEW_SECRET del CMS (solo lato server)
PREVIEW_SECRET=changeme

# Webhook rebuild (ISR): stesso valore del REVALIDATE_SECRET del CMS
REVALIDATE_SECRET=changeme

# static | isr  (di norma passato dagli script build:static / build:isr)
# BUILD_MODE=isr
