# --- Server ---
HOST=0.0.0.0
PORT=1337
# Prod dietro proxy Coolify: URL pubblico + trust X-Forwarded-*.
# In locale lasciali vuoto/false.
PUBLIC_URL=
IS_PROXIED=false

# --- Secret (genera valori casuali, NON usare questi) ---
# node -e "for(let i=0;i<7;i++)console.log(require('crypto').randomBytes(16).toString('base64'))"
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified

# --- Database ---
# sqlite per test locale; postgres in prod (server DB centralizzato)
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# postgres (usati solo se DATABASE_CLIENT=postgres)
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=newsite
DATABASE_USERNAME=newsite
DATABASE_PASSWORD=
DATABASE_SSL=false
DATABASE_SCHEMA=public

# --- Preview ---
# URL pubblico del frontend (deploy ISR/dev) + secret condiviso
CLIENT_URL=http://localhost:3005
PREVIEW_SECRET=changeme

# --- Webhook rebuild (su publish/unpublish, con debounce) ---
REBUILD_DEBOUNCE_MS=5000
# ISR: endpoint revalidate del frontend + secret condiviso
REVALIDATE_URL=http://localhost:3005/api/revalidate
REVALIDATE_SECRET=changeme
# Static: deploy hook Coolify / Cloudflare Pages (rebuild completo)
DEPLOY_HOOK_URL=
